# Reddit API credentials
# Get these by creating a free app at https://www.reddit.com/prefs/apps
# Choose "script" as the app type. No login required for read-only scraping.

REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here

# Required: Reddit enforces a specific User-Agent format or they'll block/throttle you.
# Format: <platform>:<app_id>:<version> (by /u/<your_reddit_username>)
# Replace YOUR_APP_ID with your app's client_id, and your actual Reddit username.
REDDIT_USER_AGENT=script:FanVerse-scraper:v0.1 (by /u/your_reddit_username_here)
